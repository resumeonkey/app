# ── AI providers (at least one required) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# Provider options : openai | groq | gemini | anthropic
# Model examples  :
#   openai    → gpt-4o, gpt-4o-mini
#   groq      → llama3-70b-8192, mixtral-8x7b-32768  (free tier available)
#   gemini    → gemini-2.0-flash, gemini-1.5-pro
#   anthropic → claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev: leave as SQLite (default, no setup needed)
# DATABASE_URL=sqlite:///./resume_adapter.db
# Production: use Supabase PostgreSQL connection string
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Leave empty for local dev (files stored in ./uploads and ./outputs)
# Get these from: Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=resumes

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Vercel URL in production.
ALLOWED_ORIGINS=http://localhost:3000

# ── Local dev only ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_MB=20
DEBUG=false
